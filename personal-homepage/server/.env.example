# 复制为 .env 后填写（切勿提交 .env 到 Git）

# OpenAI 或兼容接口
OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

PORT=3457
# 监听地址：0.0.0.0 允许局域网手机访问；127.0.0.1 仅本机
BIND_HOST=0.0.0.0

# 音乐库目录（默认项目内 music/，可改为其它本地路径）
MUSIC_ROOT=

# 可选：保护 POST /api/music/reindex，请求头 X-Admin-Token: <值>
# ADMIN_TOKEN=your-random-secret
